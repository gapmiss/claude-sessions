{
  "name": "agent-sessions",
  "version": "0.1.0",
  "description": "Replay AI coding agent sessions",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin"
  ],
  "author": "@gapmiss",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^16.11.6",
    "builtin-modules": "^5.0.0",
    "esbuild": "0.25.5",
    "eslint-plugin-obsidianmd": "0.1.9",
    "globals": "14.0.0",
    "tslib": "2.4.0",
    "typescript": "5.8.2",
    "typescript-eslint": "8.35.1",
    "@eslint/js": "9.30.1",
    "jiti": "2.6.1"
  },
  "dependencies": {
    "obsidian": "latest"
  }
}
